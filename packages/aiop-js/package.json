{
  "name": "@actproof/aiop",
  "version": "0.1.0",
  "description": "Minimal proof-carrying execution format for agent and automation workflows",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aiop",
    "actproof",
    "proof",
    "verification",
    "agent",
    "ai",
    "trust",
    "canonical",
    "deterministic",
    "execution-proof"
  ],
  "author": "ActProof",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/actproof/aiop-proof"
  },
  "homepage": "https://actproof.io",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
